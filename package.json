    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.3",
    "@lezer/highlight": "^1.2.3",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "fast-xml-parser": "^5.5.7",
